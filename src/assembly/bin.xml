<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2
                              http://maven.apache.org/xsd/assembly-1.1.2.xsd">
  <id>bin</id>
  <formats>
    <format>zip</format>
  </formats>

  <!--
    Wrap everything inside a top-level directory so that unzipping is clean:
      symfonion-<version>/bin/symfonion
      symfonion-<version>/lib/symfonion-<version>.jar
  -->
  <includeBaseDirectory>true</includeBaseDirectory>
  <baseDirectory>${project.artifactId}-${project.version}</baseDirectory>

  <fileSets>
    <!--
      Unix launcher: force LF line endings and mark executable.
      <filtered>true</filtered> lets Maven substitute ${project.version}
      inside the script source so it references the exact versioned jar.
    -->
    <fileSet>
      <directory>src/main/dist/bin</directory>
      <outputDirectory>bin</outputDirectory>
      <fileMode>0755</fileMode>
      <filtered>true</filtered>
      <lineEnding>unix</lineEnding>
      <includes>
        <include>symfonion</include>
      </includes>
    </fileSet>

    <!--
      Built-in YAML++ prelude: the standard-library / syntax-sugar layer for
      the Symfonion language.  The launcher sets JF_PATH so that jq++ resolves
      these files automatically; users and projects can prepend their own paths
      to override individual definitions.
    -->
    <fileSet>
      <directory>src/main/dist/share/symfonion/prelude</directory>
      <outputDirectory>share/symfonion/prelude</outputDirectory>
      <fileMode>0644</fileMode>
    </fileSet>
  </fileSets>

  <files>
    <!--
      Copy the shaded jar into lib/ with its full versioned name.
      The launcher scripts reference this exact filename after filtering.
    -->
    <file>
      <source>${project.build.directory}/symfonion-${project.version}-shaded.jar</source>
      <outputDirectory>lib</outputDirectory>
      <destName>symfonion-${project.version}.jar</destName>
    </file>
  </files>
</assembly>
